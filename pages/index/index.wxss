.page-shell {
  min-height: 100vh;
  padding: 32rpx;
  background:
    radial-gradient(circle at top left, rgba(147, 197, 253, 0.35), transparent 30%),
    radial-gradient(circle at bottom right, rgba(196, 181, 253, 0.35), transparent 28%),
    #f4f6fb;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 32rpx;
  box-shadow: 0 20rpx 50rpx rgba(32, 51, 84, 0.12);
}

.article-panel {
  position: relative;
  padding: 36rpx;
}

.badge,
.message-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 39, 0.08);
  color: #111827;
  font-size: 24rpx;
  font-weight: 600;
}

.article-title {
  margin-top: 20rpx;
  font-size: 56rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #102033;
}

.article-meta,
.message-meta,
.assistant-label {
  margin-top: 16rpx;
  color: #617086;
  font-size: 24rpx;
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.article-content {
  margin-top: 28rpx;
}

.article-paragraph {
  margin-top: 18rpx;
  color: #102033;
  font-size: 30rpx;
  line-height: 1.9;
}

.article-summary-box {
  margin-top: 28rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 2rpx dashed rgba(16, 32, 51, 0.14);
}

.summary-label,
.section-title,
.assistant-title,
.message-title {
  color: #102033;
  font-weight: 700;
}

.summary-label,
.assistant-label,
.theme-item,
.digest-line,
.message-text,
.digest-summary {
  font-size: 26rpx;
}

.summary-text,
.message-text,
.digest-summary,
.digest-line,
.empty-state,
.theme-item {
  margin-top: 12rpx;
  color: #617086;
  line-height: 1.7;
}

.floating-button {
  position: absolute;
  right: 28rpx;
  bottom: 28rpx;
  width: 112rpx;
  height: 112rpx;
  padding: 0;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #1f2937, #030712);
  color: #ffffff;
  box-shadow: 0 16rpx 36rpx rgba(17, 24, 39, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.floating-button::after,
.toggle-button::after {
  border: none;
}

.floating-button text {
  font-size: 56rpx;
  line-height: 1;
}

.assistant-panel {
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.assistant-header {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: flex-start;
}

.assistant-title {
  margin-top: 12rpx;
  font-size: 42rpx;
}

.toggle-button {
  margin: 0;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #102033;
  border: 2rpx solid rgba(16, 32, 51, 0.1);
  font-size: 26rpx;
}

.card-section,
.digest-section {
  padding: 20rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(16, 32, 51, 0.1);
  background: rgba(255, 255, 255, 0.8);
}

.message-item,
.digest-item {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: #ffffff;
  border: 2rpx solid rgba(16, 32, 51, 0.08);
}

.message-title {
  margin-top: 12rpx;
  font-size: 30rpx;
  line-height: 1.45;
}

.digest-summary {
  color: #102033;
}

.theme-list,
.digest-lines {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.theme-item {
  padding: 16rpx;
  border-radius: 18rpx;
  background: rgba(219, 234, 254, 0.55);
  color: #23457a;
}

.digest-line {
  padding: 16rpx;
  border-radius: 18rpx;
  background: #f9fbff;
}

.empty-state {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 2rpx dashed rgba(16, 32, 51, 0.16);
}


.digest-block {
  margin-top: 22rpx;
}

.digest-block__title {
  color: #102033;
  font-size: 28rpx;
  font-weight: 700;
}

.digest-paragraph {
  margin-top: 12rpx;
  color: #617086;
  font-size: 26rpx;
  line-height: 1.75;
}
